#!/usr/bin/env bash
#
# wt - Interactive git worktree dashboard
#
# Features:
#   - Browse all worktrees with fzf TUI
#   - Preview panel with branch, commits, submodules, status
#   - Create, delete, pull, and open worktrees with keybindings
#   - Shell integration for cd support
#
# Usage:
#   wt              Auto-detect repo from $PWD
#   wt <path>       Use specific repo path
#   wt -h|--help    Show help
#
# Requirements: git, fzf (0.38+)
#

set -euo pipefail

# =============================================================================
# Configuration
# =============================================================================

readonly VERSION="0.1.1"

# Resolve absolute path to this script for fzf callbacks
_resolve_self() {
    local source="${BASH_SOURCE[0]}"
    while [[ -L "$source" ]]; do
        local dir
        dir=$(cd -P "$(dirname "$source")" && pwd)
        source=$(readlink "$source")
        [[ "$source" != /* ]] && source="$dir/$source"
    done
    echo "$(cd -P "$(dirname "$source")" && pwd)/$(basename "$source")"
}
SELF="$(_resolve_self)"
readonly SELF

# Colors
readonly RED=$'\033[31m'
readonly GREEN=$'\033[32m'
readonly BLUE=$'\033[34m'
readonly YELLOW=$'\033[33m'
readonly DIM=$'\033[2m'
readonly BOLD=$'\033[1m'
readonly NC=$'\033[0m'

# =============================================================================
# Utility Functions
# =============================================================================

die() {
    echo "${RED}error:${NC} $*" >&2
    exit 1
}

warn() {
    echo "${YELLOW}warning:${NC} $*" >&2
}

# Turn a missing command into a concrete install command.
#
# First principles:
# - "missing dependency" errors are only useful if they tell the user what to
#   do next.
# - `wt` is a small shell tool, so we keep the dependency story equally small:
#   name the missing tool, name the job it was needed for, then show one
#   install command that likely works on the current machine.
install_hint_for() {
    local cmd="$1"

    case "$cmd" in
        fzf)
            if command -v brew >/dev/null 2>&1; then
                echo "brew install fzf"
            elif command -v apt-get >/dev/null 2>&1 || command -v apt >/dev/null 2>&1; then
                echo "sudo apt install fzf"
            elif command -v dnf >/dev/null 2>&1; then
                echo "sudo dnf install fzf"
            elif command -v pacman >/dev/null 2>&1; then
                echo "sudo pacman -S fzf"
            elif command -v zypper >/dev/null 2>&1; then
                echo "sudo zypper install fzf"
            elif command -v apk >/dev/null 2>&1; then
                echo "sudo apk add fzf"
            elif command -v xbps-install >/dev/null 2>&1; then
                echo "sudo xbps-install -S fzf"
            elif command -v pkg >/dev/null 2>&1; then
                echo "pkg install fzf"
            elif command -v pkg_add >/dev/null 2>&1; then
                echo "pkg_add fzf"
            elif command -v pkgin >/dev/null 2>&1; then
                echo "pkgin install fzf"
            elif command -v emerge >/dev/null 2>&1; then
                echo "emerge --ask app-shells/fzf"
            elif command -v nix-env >/dev/null 2>&1; then
                echo "nix-env -iA nixpkgs.fzf"
            else
                echo "https://github.com/junegunn/fzf#installation"
            fi
            ;;
        git)
            if command -v brew >/dev/null 2>&1; then
                echo "brew install git"
            elif command -v apt-get >/dev/null 2>&1 || command -v apt >/dev/null 2>&1; then
                echo "sudo apt install git"
            elif command -v dnf >/dev/null 2>&1; then
                echo "sudo dnf install git"
            elif command -v pacman >/dev/null 2>&1; then
                echo "sudo pacman -S git"
            elif command -v zypper >/dev/null 2>&1; then
                echo "sudo zypper install git"
            elif command -v apk >/dev/null 2>&1; then
                echo "sudo apk add git"
            elif command -v xbps-install >/dev/null 2>&1; then
                echo "sudo xbps-install -S git"
            elif command -v pkg >/dev/null 2>&1; then
                echo "pkg install git"
            elif command -v pkg_add >/dev/null 2>&1; then
                echo "pkg_add git"
            elif command -v pkgin >/dev/null 2>&1; then
                echo "pkgin install git"
            elif command -v emerge >/dev/null 2>&1; then
                echo "emerge --ask dev-vcs/git"
            elif command -v nix-env >/dev/null 2>&1; then
                echo "nix-env -iA nixpkgs.git"
            else
                echo "https://git-scm.com/downloads"
            fi
            ;;
        *)
            echo ""
            ;;
    esac
}

require_command() {
    local cmd="$1" purpose="${2:-}"
    local hint

    command -v "$cmd" >/dev/null 2>&1 && return 0

    hint=$(install_hint_for "$cmd")
    if [[ -n "$purpose" ]]; then
        die "$cmd is required for $purpose. Install it with: $hint"
    fi

    die "$cmd is required. Install it with: $hint"
}

# A stale worktree cannot prune itself because its directory is already gone.
# We need any surviving checkout from the SAME repo whose worktree metadata
# still contains the missing path.
worktree_known_to_git_context() {
    local git_ctx="$1" wt_path="$2"
    worktree_state_from_context "$git_ctx" "$wt_path" >/dev/null 2>&1
}

worktree_state_from_context() {
    local git_ctx="$1" wt_path="$2"
    git -C "$git_ctx" rev-parse --git-dir >/dev/null 2>&1 || return 1
    wt_path=$(canonical_path "$wt_path")

    # We only need one worktree's state, but Git gives us the whole porcelain
    # stream. Walk the records once and return the state for the matching path.
    #
    # Why this helper exists:
    # - A stale/prunable worktree can still have files on disk.
    # - "Directory exists" and "valid worktree" are different questions.
    # - Ctrl-X needs Git's opinion about the entry, not just the filesystem.
    local current_path="" state="branch" locked=""
    local line

    while IFS= read -r line || [[ -n "$line" ]]; do
        if [[ -z "$line" ]]; then
            if [[ "$current_path" == "$wt_path" ]]; then
                printf '%s\t%s\n' "$state" "$locked"
                return 0
            fi
            current_path="" state="branch" locked=""
            continue
        fi

        case "$line" in
            worktree\ *) current_path=$(canonical_path "${line#worktree }") ;;
            detached)    state="detached" ;;
            prunable*)   state="prunable" ;;
            locked*)     locked="yes" ;;
        esac
    done < <(git -C "$git_ctx" worktree list --porcelain 2>/dev/null)

    if [[ "$current_path" == "$wt_path" ]]; then
        printf '%s\t%s\n' "$state" "$locked"
        return 0
    fi

    return 1
}

# Prefer the explicit repo context passed from the dashboard. That matters when
# the missing worktree lives far away from its siblings, so scanning the parent
# directory would never find a checkout from the right repo.
find_prune_context() {
    local wt_path="$1" preferred_ctx="${2:-}"

    if [[ -n "$preferred_ctx" ]] && worktree_known_to_git_context "$preferred_ctx" "$wt_path"; then
        echo "$preferred_ctx"
        return 0
    fi

    local parent_dir sibling
    parent_dir=$(dirname "$wt_path")
    for sibling in "$parent_dir"/*/; do
        sibling="${sibling%/}"
        [[ -d "$sibling" ]] || continue
        if worktree_known_to_git_context "$sibling" "$wt_path"; then
            echo "$sibling"
            return 0
        fi
    done

    return 1
}

# Prune immediately. In this flow the user just deleted or selected this exact
# worktree, so waiting for Git's normal prune expiry is confusing.
prune_worktree_metadata() {
    local wt_path="$1" preferred_ctx="${2:-}"
    local git_ctx=""

    git_ctx=$(find_prune_context "$wt_path" "$preferred_ctx") || return 1
    git -C "$git_ctx" worktree prune --expire now >/dev/null 2>&1
}

# A clean worktree can become dirty between the first confirmation screen and
# the actual delete call. If Git refuses a normal remove at that point, re-check
# the worktree and require an explicit force-delete confirmation.
confirm_force_delete() {
    local wt_path="$1"
    local status_output="" dirty_count=0 line confirm status_exit=0 status_unknown=0

    status_output=$(git -C "$wt_path" status --porcelain 2>/dev/null) || status_exit=$?
    if [[ -n "$status_output" ]]; then
        dirty_count=$(wc -l <<< "$status_output" | tr -d ' ')
    elif (( status_exit != 0 )); then
        status_unknown=1
    fi

    if (( dirty_count == 0 )) && (( status_unknown == 0 )); then
        return 0
    fi

    echo ""
    if (( status_unknown != 0 )); then
        echo "${YELLOW}Warning:${NC} Unable to determine Git status for this worktree."
        echo "${RED}${BOLD}Filesystem cleanup may permanently delete untracked or uncommitted changes.${NC}"
    else
        echo "${YELLOW}Worktree now has $dirty_count uncommitted change(s):${NC}"
        while IFS= read -r line; do
            [[ -n "$line" ]] && echo "  ${DIM}$line${NC}"
        done < <(head -10 <<< "$status_output")
        (( dirty_count > 10 )) && echo "  ${DIM}… and $((dirty_count - 10)) more${NC}"

        echo ""
        echo "${RED}${BOLD}Filesystem cleanup would permanently delete those changes.${NC}"
    fi

    printf '%s' "${BOLD}Type 'delete' to force removal: ${NC}"
    read -r confirm
    [[ "$confirm" == "delete" ]]
}

# "Permission denied" from rm -rf usually means the remaining path is blocked by
# directory permissions, ACLs, or macOS immutable flags. Fix the blockers first,
# then let the next delete attempt remove the tree normally.
#
# Only touch paths INSIDE the worktree itself. Symlinks are skipped so we never
# mutate a target outside the worktree by accident.
repair_delete_barriers() {
    local wt_path="$1" entry _attempt

    for _attempt in 1 2 3; do
        [[ -e "$wt_path" ]] || return 0

        chmod u+rwx "$wt_path" 2>/dev/null || true
        chmod -N "$wt_path" 2>/dev/null || true

        while IFS= read -r entry; do
            [[ -n "$entry" ]] || continue

            # rm -rf often gets stuck on unreadable directories. Walk
            # directories in pre-order so we can fix the next blocked node
            # before the subsequent delete retry.
            [[ -L "$entry" ]] && continue
            chmod u+rwx "$entry" 2>/dev/null || true
            chmod -N "$entry" 2>/dev/null || true
        done < <(find "$wt_path" -type d -print 2>/dev/null || true)

        while IFS= read -r entry; do
            [[ -n "$entry" ]] || continue
            [[ -L "$entry" ]] && continue
            chmod -N "$entry" 2>/dev/null || true
            if command -v chflags >/dev/null 2>&1; then
                chflags nouchg,noschg "$entry" 2>/dev/null || true
            fi
        done < <(find "$wt_path" -print 2>/dev/null || true)
    done
}

# Git and the filesystem can diverge here: `git worktree remove` may succeed in
# removing metadata but leave unreadable directories behind, or it may fail
# after partially deleting the tree. This helper finishes the filesystem side
# and prints concrete diagnostics if the path still cannot be removed.
delete_worktree_path() {
    local wt_path="$1" _attempt
    local remove_output="" rm_output

    for _attempt in 1 2 3; do
        [[ -e "$wt_path" ]] || return 0

        if rm_output=$(rm -rf -- "$wt_path" 2>&1); then
            [[ -n "$rm_output" ]] && remove_output+="$rm_output"$'\n'
        else
            [[ -n "$rm_output" ]] && remove_output+="$rm_output"$'\n'
        fi

        [[ ! -e "$wt_path" ]] && return 0

        repair_delete_barriers "$wt_path"

        if [[ -d "$wt_path" ]] && [[ -z "$(find "$wt_path" -mindepth 1 -print -quit 2>/dev/null || true)" ]]; then
            rmdir -- "$wt_path" 2>/dev/null || true
        fi

        [[ ! -e "$wt_path" ]] && return 0
    done

    if [[ -n "$remove_output" ]]; then
        printf '%s' "$remove_output" | sed '/^$/d' | sed 's/^/  /'
    fi

    echo "${RED}Directory still exists after multiple cleanup attempts.${NC}"

    local current_user entry shown owner_mismatch
    current_user=$(id -un)

    shown=0
    while IFS= read -r entry; do
        [[ -n "$entry" ]] || continue
        if (( shown == 0 )); then
            echo "${DIM}Remaining entries:${NC}"
        fi
        printf '  %s\n' "$(shorten_path "$entry")"
        shown=$(( shown + 1 ))
        (( shown >= 10 )) && break
    done < <(find "$wt_path" -mindepth 1 -maxdepth 2 -print 2>/dev/null || true)

    owner_mismatch=$(find "$wt_path" ! -user "$current_user" -print -quit 2>/dev/null || true)
    if [[ -n "$owner_mismatch" ]]; then
        echo "${DIM}Some remaining entries are not owned by $current_user.${NC}"
    fi

    echo "${DIM}Inspect with: ls -ldOe \"$wt_path\" \"$wt_path\"/*${NC}"
    return 1
}

canonical_path() {
    # Resolve symlinks without GNU realpath (unavailable on older macOS).
    # Handles /tmp → /private/tmp style symlinks that break path comparisons.
    # Missing paths still need canonicalization too, because Git may remember a
    # deleted worktree as /private/... while the user selected /var/...
    local path="$1"
    if [[ -d "$path" ]]; then
        (cd -P "$path" 2>/dev/null && pwd) || echo "$path"
    elif [[ -e "$path" ]]; then
        local dir base
        dir=$(cd -P "$(dirname "$path")" 2>/dev/null && pwd) || { echo "$path"; return; }
        base=$(basename "$path")
        echo "$dir/$base"
    else
        local parent base
        parent=$(dirname "$path")
        base=$(basename "$path")
        if parent=$(cd -P "$parent" 2>/dev/null && pwd); then
            echo "$parent/$base"
        else
            echo "$path"
        fi
    fi
}

shorten_path() {
    echo "${1/#$HOME/~}"
}

truncate_str() {
    local str="$1" max="$2"
    if (( ${#str} > max )); then
        echo "${str:0:$((max - 1))}…"
    else
        echo "$str"
    fi
}

# Keep both ends of a long identifier visible.
#
# Why this exists:
# - Worktree paths usually share a long common prefix.
# - The part that distinguishes one worktree from another is often near the end.
# - Normal left-to-right truncation hides exactly that useful tail.
#
# Example:
#   /Users/me/src/monolith/feature/auth-refresh
# becomes
#   /Users/me/src…feature/auth-refresh
truncate_middle() {
    local str="$1" max="$2"
    if (( ${#str} <= max )); then
        echo "$str"
        return
    fi

    if (( max < 5 )); then
        truncate_str "$str" "$max"
        return
    fi

    local left right
    left=$(( (max - 1) / 2 ))
    right=$(( max - 1 - left ))
    echo "${str:0:$left}…${str: -$right}"
}

terminal_columns() {
    local cols
    cols=$(tput cols 2>/dev/null || true)
    if [[ ! "$cols" =~ ^[0-9]+$ ]] || (( cols <= 0 )); then
        cols=80
    fi
    echo "$cols"
}

terminal_lines() {
    local lines
    lines=$(tput lines 2>/dev/null || true)
    if [[ ! "$lines" =~ ^[0-9]+$ ]] || (( lines <= 0 )); then
        lines=24
    fi
    echo "$lines"
}

preview_columns() {
    local cols="${FZF_PREVIEW_COLUMNS:-}"
    # When fzf runs a preview command it tells us the actual preview width via
    # FZF_PREVIEW_COLUMNS. Outside fzf (manual testing, docs examples, plain
    # script calls) that variable does not exist, so we fall back to the
    # current terminal width.
    if [[ ! "$cols" =~ ^[0-9]+$ ]] || (( cols <= 0 )); then
        cols=$(terminal_columns)
    fi
    echo "$cols"
}

# "Compact" means "this preview pane is too narrow for table-like rows".
# Once we cross that point, stacked multi-line output is easier to read than
# trying to preserve columns that will wrap into each other.
preview_is_compact() {
    local cols
    cols=$(preview_columns)
    (( cols < 72 ))
}

# Pick the preview placement from the terminal shape instead of hardcoding a
# right-side split for every terminal.
#
# Design rule:
# - Wide terminals can afford side-by-side list + preview.
# - Narrow terminals cannot, so the preview must move below the list.
#
# The exact numbers are heuristics, not protocol. If this is ever retuned,
# keep the first-principles goal the same: preserve the list's identifying path
# column first, then give the preview whatever space remains.
choose_preview_window() {
    local cols lines
    cols=$(terminal_columns)
    lines=$(terminal_lines)

    if (( cols >= 150 && cols >= lines * 2 )); then
        echo "right,55%,wrap"
    elif (( cols >= 120 && cols >= lines * 3 / 2 )); then
        echo "right,50%,wrap"
    elif (( lines >= 40 )); then
        echo "down,45%,wrap"
    else
        echo "down,55%,wrap"
    fi
}

# Convert unix timestamp to compact relative time: 1709312400 → "3d ago"
timestamp_to_relative() {
    local ts="$1" now="$2"
    local diff=$(( now - ts ))

    if (( diff < 0 )); then       echo "now"
    elif (( diff < 60 )); then    echo "${diff}s ago"
    elif (( diff < 3600 )); then  echo "$(( diff / 60 ))m ago"
    elif (( diff < 86400 )); then echo "$(( diff / 3600 ))h ago"
    elif (( diff < 604800 )); then    echo "$(( diff / 86400 ))d ago"
    elif (( diff < 2592000 )); then   echo "$(( diff / 604800 ))w ago"
    elif (( diff < 31536000 )); then  echo "$(( diff / 2592000 ))mo ago"
    else                              echo "$(( diff / 31536000 ))y ago"
    fi
}

# Find the newest commit visible from a worktree and its initialized
# submodules. This is intentionally expensive, so callers should only use it in
# lazy or background paths, never in the synchronous startup list.
#
# Output is written to globals instead of echoing a delimited string. That
# keeps commit subjects tab-safe: `%s` can contain literal tab characters, so
# tab-delimited parsing would corrupt the subject/source split.
#
# Sets:
#   NEWEST_COMMIT_TS
#   NEWEST_COMMIT_SUBJECT
#   NEWEST_COMMIT_SOURCE
get_newest_commit() {
    local wt_path="$1"

    NEWEST_COMMIT_TS=0
    NEWEST_COMMIT_SUBJECT=""
    NEWEST_COMMIT_SOURCE=""

    [[ -d "$wt_path" ]] || return

    local mono_info
    mono_info=$(git -C "$wt_path" log -1 --format=$'%ct\t%s' HEAD 2>/dev/null) || return

    NEWEST_COMMIT_TS="${mono_info%%	*}"
    NEWEST_COMMIT_SUBJECT="${mono_info#*	}"

    if [[ ! -f "$wt_path/.gitmodules" ]]; then
        return
    fi

    local sub_path sub_info sub_ts entry
    while IFS= read -r -d '' entry; do
        [[ -z "$entry" ]] && continue
        sub_path="${entry#*$'\n'}"
        [[ -d "$wt_path/$sub_path" ]] || continue
        sub_info=$(git -C "$wt_path/$sub_path" log -1 --format=$'%ct\t%s' HEAD 2>/dev/null) || continue
        sub_ts="${sub_info%%	*}"
        if (( sub_ts > NEWEST_COMMIT_TS )); then
            NEWEST_COMMIT_TS="$sub_ts"
            NEWEST_COMMIT_SUBJECT="${sub_info#*	}"
            NEWEST_COMMIT_SOURCE="$sub_path"
        fi
    done < <(git -C "$wt_path" config --file .gitmodules -z --get-regexp 'submodule\..*\.path' 2>/dev/null)
}

# =============================================================================
# Worktree Parsing
# =============================================================================

# Parses `git worktree list --porcelain` into parallel arrays.
# Sets: WT_PATHS, WT_BRANCHES, WT_STATES, WT_LOCKED
parse_worktrees() {
    local git_args=("worktree" "list" "--porcelain")
    [[ -n "${REPO_PATH:-}" ]] && git_args=("-C" "$REPO_PATH" "${git_args[@]}")

    WT_PATHS=()
    WT_BRANCHES=()
    WT_STATES=()
    WT_LOCKED=()

    local path="" branch="" state="branch" locked=""

    while IFS= read -r line || [[ -n "$line" ]]; do
        if [[ -z "$line" ]]; then
            if [[ -n "$path" ]]; then
                WT_PATHS+=("$(canonical_path "$path")")
                WT_BRANCHES+=("$branch")
                WT_STATES+=("$state")
                WT_LOCKED+=("$locked")
            fi
            path="" branch="" state="branch" locked=""
            continue
        fi

        case "$line" in
            worktree\ *)  path="${line#worktree }" ;;
            branch\ *)    branch="${line#branch refs/heads/}" ;;
            detached)     state="detached" ;;
            prunable*)    state="prunable" ;;
            locked*)      locked="yes" ;;
        esac
    done < <(git "${git_args[@]}")

    # Handle last block (porcelain output may not end with a blank line)
    if [[ -n "$path" ]]; then
        WT_PATHS+=("$(canonical_path "$path")")
        WT_BRANCHES+=("$branch")
        WT_STATES+=("$state")
        WT_LOCKED+=("$locked")
    fi
}

# Most worktree setups put sibling worktrees next to the main checkout. Use
# that parent directory as the default "base" for list display and header text.
#
# Why not use the strict common prefix of every worktree path?
# Because one odd path in /tmp or another directory would force the shared
# prefix all the way back to "/", which makes every normal worktree row worse.
worktree_base_dir() {
    (( ${#WT_PATHS[@]} == 0 )) && return

    local base
    base=$(dirname "${WT_PATHS[0]}")
    [[ "$base" != */ ]] && base="$base/"
    printf '%s\n' "$base"
}

# The list must stay cheap because fzf waits for the full list before the UI
# appears. That means the list may only use metadata we already got from
# `git worktree list --porcelain`.
#
# Anything more expensive, especially `git log` across worktrees or submodules,
# belongs in the preview because the preview is lazy and only runs for the
# highlighted row.
list_row_label() {
    local index="$1"
    local state="${WT_STATES[$index]}"
    local branch="${WT_BRANCHES[$index]}"
    local locked="${WT_LOCKED[$index]}"

    if [[ -n "$locked" ]]; then
        if [[ -n "$branch" ]]; then
            printf 'locked • %s\n' "$branch"
        else
            printf 'locked\n'
        fi
        return
    fi

    case "$state" in
        prunable)
            printf 'prunable\n'
            ;;
        detached)
            printf 'detached\n'
            ;;
        *)
            printf '%s\n' "${branch:-branch}"
            ;;
    esac
}

ensure_repo_context() {
    # Validate repo before parsing — commands like --list can be called
    # directly by fzf reload actions, so we cannot rely on main() having
    # already done the repo validation.
    if [[ -n "${REPO_PATH:-}" ]]; then
        git -C "$REPO_PATH" rev-parse --git-dir >/dev/null 2>&1 \
            || die "Not a git repository: $REPO_PATH"
    else
        git rev-parse --git-dir >/dev/null 2>&1 \
            || die "Not inside a git repository"
    fi
}

activity_row_payload() {
    local wt_path="$1" fallback="$2" now="$3"
    ACTIVITY_ROW_TS=0
    ACTIVITY_ROW_AGE="—"
    ACTIVITY_ROW_SUBJECT="$fallback"

    # This is the bridge between the fast startup list and the richer
    # activity-sorted list. If history lookup fails, keep the cheap fallback
    # label instead of failing the whole background refresh.
    get_newest_commit "$wt_path"

    if [[ "$NEWEST_COMMIT_TS" != "0" ]]; then
        ACTIVITY_ROW_TS="$NEWEST_COMMIT_TS"
        ACTIVITY_ROW_AGE=$(timestamp_to_relative "$NEWEST_COMMIT_TS" "$now")
        if [[ -n "$NEWEST_COMMIT_SOURCE" ]]; then
            ACTIVITY_ROW_SUBJECT="${NEWEST_COMMIT_SOURCE}: ${NEWEST_COMMIT_SUBJECT}"
        elif [[ -n "$NEWEST_COMMIT_SUBJECT" ]]; then
            ACTIVITY_ROW_SUBJECT="$NEWEST_COMMIT_SUBJECT"
        fi
    fi
}

# =============================================================================
# List Command
# =============================================================================

# Outputs tab-delimited rows for fzf using only cheap worktree metadata.
# Field 1 (hidden): full worktree path
# Field 2 (visible): icon, worktree path, branch/state label
cmd_list() {
    require_command git "worktree inspection"
    ensure_repo_context
    parse_worktrees

    if (( ${#WT_PATHS[@]} == 0 )); then
        return
    fi

    local base_dir=""
    base_dir=$(worktree_base_dir)

    local current_wt i
    current_wt=$(canonical_path "${PWD:-}")

    # Sort current first, then regular worktrees, then detached, then stale.
    # This is cheap to compute and keeps the fast-startup list predictable.
    local rows=()

    for (( i = 0; i < ${#WT_PATHS[@]}; i++ )); do
        local path="${WT_PATHS[$i]}"
        local state="${WT_STATES[$i]}"

        # Determine icon and color — current worktree takes priority
        local icon color is_current=false

        if [[ -n "$current_wt" && ( "$current_wt" == "$path" || "$current_wt" == "$path/"* ) ]]; then
            is_current=true
        fi

        if $is_current; then
            icon="●" color="$GREEN"
        else
            case "$state" in
                prunable)  icon="✗" color="$RED" ;;
                detached)  icon="◌" color="$YELLOW" ;;
                *)         icon="○" color="$BLUE" ;;
            esac
        fi

        # Locked worktrees override the icon
        if [[ -n "${WT_LOCKED[$i]}" ]]; then
            icon="🔒" color="$DIM"
        fi

        # The visible row puts the path before commit text on purpose.
        # The path answers "which worktree is this?" while the dim label only
        # answers "what state is it in?" Identity comes first.
        local sort_path display_path
        if [[ -n "$base_dir" && "$path" == "$base_dir"* ]]; then
            sort_path="${path#"$base_dir"}"
            display_path="$sort_path"
        else
            sort_path="$path"
            display_path=$(shorten_path "$path")
        fi
        display_path=$(truncate_middle "$display_path" 30)

        local label sort_group
        label=$(truncate_str "$(list_row_label "$i")" 24)

        if $is_current; then
            sort_group=0
        else
            case "$state" in
                detached) sort_group=2 ;;
                prunable) sort_group=3 ;;
                *)        sort_group=1 ;;
            esac
        fi

        # Collect: group\x1fpath_sort_key\x1fformatted_row
        local row
        row=$(printf "%s\x1f %s%s %-30s%s  %s%s%s" \
            "$path" \
            "$color" "$icon" "$display_path" "$NC" \
            "$DIM" "$label" "$NC")

        rows+=("${sort_group}"$'\x1f'"${sort_path}"$'\x1f'"${row}")
    done

    printf '%s\n' "${rows[@]}" | sort -t$'\x1f' -k1,1n -k2,2f | cut -d$'\x1f' -f3-
}

cmd_list_activity() {
    require_command git "worktree activity inspection"
    ensure_repo_context

    parse_worktrees

    if (( ${#WT_PATHS[@]} == 0 )); then
        return
    fi

    local base_dir=""
    base_dir=$(worktree_base_dir)

    local current_wt now i
    current_wt=$(canonical_path "${PWD:-}")
    now=$(date +%s)

    local rows=()

    for (( i = 0; i < ${#WT_PATHS[@]}; i++ )); do
        local path="${WT_PATHS[$i]}"
        local state="${WT_STATES[$i]}"

        local icon color is_current=false
        if [[ -n "$current_wt" && ( "$current_wt" == "$path" || "$current_wt" == "$path/"* ) ]]; then
            is_current=true
        fi

        if $is_current; then
            icon="●" color="$GREEN"
        else
            case "$state" in
                prunable)  icon="✗" color="$RED" ;;
                detached)  icon="◌" color="$YELLOW" ;;
                *)         icon="○" color="$BLUE" ;;
            esac
        fi

        if [[ -n "${WT_LOCKED[$i]}" ]]; then
            icon="🔒" color="$DIM"
        fi

        local sort_path display_path
        if [[ -n "$base_dir" && "$path" == "$base_dir"* ]]; then
            sort_path="${path#"$base_dir"}"
            display_path="$sort_path"
        else
            sort_path="$path"
            display_path=$(shorten_path "$path")
        fi
        display_path=$(truncate_middle "$display_path" 30)

        local fallback_label max_ts age subject
        fallback_label=$(list_row_label "$i")
        activity_row_payload "$path" "$fallback_label" "$now"
        max_ts="$ACTIVITY_ROW_TS"
        age="$ACTIVITY_ROW_AGE"
        subject=$(truncate_str "$ACTIVITY_ROW_SUBJECT" 52)

        local row
        row=$(printf "%s\x1f %s%s %-30s%s  %s%-8s%s  %s" \
            "$path" \
            "$color" "$icon" "$display_path" "$NC" \
            "$DIM" "$age" "$NC" \
            "$subject")

        rows+=("${max_ts}"$'\x1f'"${sort_path}"$'\x1f'"${row}")
    done

    printf '%s\n' "${rows[@]}" | sort -t$'\x1f' -k1,1rn -k2,2f | cut -d$'\x1f' -f3-
}

# =============================================================================
# Preview Command
# =============================================================================

section_header() {
    local title="$1"
    local width
    # Keep section dividers visually tied to the real preview width so the
    # preview still feels intentional in both narrow and wide panes.
    width=$(preview_columns)
    width=$(( width - 6 ))
    (( width < 24 )) && width=24
    (( width > 72 )) && width=72
    local pad=$(( width - ${#title} - 5 ))
    (( pad < 2 )) && pad=2
    printf "\n%s─── %s %s%s\n" "$BOLD" "$title" "$(printf '─%.0s' $(seq 1 "$pad"))" "$NC"
}

print_activity_line() {
    local rel="$1" hash="$2" subject="$3" source="${4:-}"
    local cols compact_width compact_subject_width
    cols=$(preview_columns)
    compact_width=$(( cols - 4 ))
    compact_subject_width=$(( compact_width - 20 ))
    (( compact_width < 12 )) && compact_width=12
    (( compact_subject_width < 12 )) && compact_subject_width=12

    # In compact mode we stop pretending we have room for aligned columns.
    # A short stacked block is easier to scan than wrapped pseudo-columns.
    if preview_is_compact; then
        printf "  %-8s  ${YELLOW}%s${NC}\n" "$rel" "$hash"
        if [[ -n "$source" ]]; then
            printf "    ${DIM}%s${NC}  %s\n" "$(truncate_str "$source" 18)" "$(truncate_str "$subject" "$compact_subject_width")"
        else
            printf "    %s\n" "$(truncate_str "$subject" "$compact_width")"
        fi
        return
    fi

    local rel_width=8 hash_width=10 source_width=0 subject_width
    hash=$(truncate_str "$hash" "$hash_width")

    if [[ -n "$source" ]]; then
        source_width=$(( cols / 5 ))
        (( source_width < 10 )) && source_width=10
        (( source_width > 18 )) && source_width=18
        source=$(truncate_str "$source" "$source_width")
    fi

    # Keep each activity row as one left-aligned thought instead of splitting
    # the source into a detached far-right column. The source is metadata, but
    # it is still part of the sentence the user is reading.
    subject_width=$(( cols - (2 + rel_width + 2 + hash_width + 2) ))
    if (( source_width > 0 )); then
        subject_width=$(( cols - (2 + rel_width + 2 + hash_width + 2 + source_width + 2) ))
    fi
    (( subject_width < 16 )) && subject_width=16
    subject=$(truncate_str "$subject" "$subject_width")

    # In wide mode we keep the one-line timeline feel with a compact source tag
    # near the hash so every row stays visually connected.
    if (( source_width > 0 )); then
        printf "  %-*s  ${YELLOW}%-*s${NC}  ${DIM}%-*s${NC}  %s\n" \
            "$rel_width" "$rel" "$hash_width" "$hash" "$source_width" "$source" "$subject"
    else
        printf "  %-*s  ${YELLOW}%-*s${NC}  %s\n" \
            "$rel_width" "$rel" "$hash_width" "$hash" "$subject"
    fi
}

# Render submodule rows with the same rule as activity rows:
# preserve columns when there is room, otherwise switch to a stacked summary.
print_submodule_line() {
    local sync_icon="$1" dirty="$2" name="$3" branch="$4" age="$5" subject="$6"
    local cols dirty_display compact_branch_width compact_subject_width
    cols=$(preview_columns)
    compact_branch_width=$(( cols / 3 ))
    compact_subject_width=$(( cols - 8 ))
    (( compact_branch_width < 10 )) && compact_branch_width=10
    (( compact_subject_width < 16 )) && compact_subject_width=16

    dirty_display=" "
    [[ -n "$dirty" ]] && dirty_display="${YELLOW}*${NC}"

    if preview_is_compact; then
        printf "  %s %s%s\n" "$sync_icon" "$dirty_display" "$name"
        printf "    %s%s%s  ${DIM}•${NC}  %s  ${DIM}•${NC}  %s\n" \
            "$DIM" "$(truncate_str "$branch" "$compact_branch_width")" "$NC" "$age" "$(truncate_str "$subject" "$compact_subject_width")"
        return
    fi

    local name_width branch_width subject_width
    name_width=$(( cols / 4 ))
    (( name_width < 16 )) && name_width=16
    (( name_width > 24 )) && name_width=24

    branch_width=$(( cols / 5 ))
    (( branch_width < 12 )) && branch_width=12
    (( branch_width > 18 )) && branch_width=18

    subject_width=$(( cols - 22 - name_width - branch_width ))
    (( subject_width < 16 )) && subject_width=16

    name=$(truncate_str "$name" "$name_width")
    branch=$(truncate_str "$branch" "$branch_width")
    subject=$(truncate_str "$subject" "$subject_width")

    printf "  %s %s%-*s %s%-*s%s  %-8s  %s\n" \
        "$sync_icon" "$dirty_display" "$name_width" "$name" \
        "$DIM" "$branch_width" "$branch" "$NC" "$age" "$subject"
}

wait_for_fzf_socket() {
    local socket_path="$1"
    local attempt=0

    while (( attempt < 200 )); do
        [[ -S "$socket_path" ]] && return 0
        sleep 0.05
        attempt=$(( attempt + 1 ))
    done

    return 1
}

post_fzf_action() {
    local socket_path="$1" action="$2"

    command -v curl >/dev/null 2>&1 || return 1
    [[ -S "$socket_path" ]] || return 1

    # fzf's --listen mode exposes a tiny local HTTP endpoint over a Unix socket.
    # We always talk to "localhost" here so the request shape stays obvious when
    # someone copies the curl command out to debug it by hand.
    curl --silent --show-error --unix-socket "$socket_path" http://localhost/ \
        -d "$action" >/dev/null 2>&1
}

start_async_refresh() {
    local socket_path="${1:?Missing fzf socket path}"
    local output_path="${2:?Missing activity output path}"
    local token_file="${3:?Missing refresh token file}"
    local pid_file="${4:?Missing refresh pid file}"
    local repo_path="${5:-}"
    local token old_pid=""

    command -v curl >/dev/null 2>&1 || return 0

    # Every refresh gets a new token. The worker will only publish its results
    # if the token is still current when it finishes. That keeps an older,
    # slower refresh from overwriting a newer one.
    token="$(date +%s)-$$-$RANDOM-$RANDOM"
    printf '%s' "$token" > "$token_file"
    if [[ -f "$pid_file" ]]; then
        old_pid=$(cat "$pid_file" 2>/dev/null || true)
        if [[ "$old_pid" =~ ^[0-9]+$ ]] && (( old_pid != $$ )) && kill -0 "$old_pid" 2>/dev/null; then
            kill "$old_pid" >/dev/null 2>&1 || true
        fi
    fi
    printf '%s' "$$" > "$pid_file"
    trap 'if [[ -f "$pid_file" ]] && [[ "$(cat "$pid_file" 2>/dev/null)" == "$$" ]]; then rm -f "$pid_file"; fi' EXIT

    if [[ -n "${WT_CAN_CHANGE_LIST_LABEL:-}" ]]; then
        post_fzf_action "$socket_path" "change-list-label(worktrees · loading activity...)" || true
    fi

    # Run the refresh worker in this process. Callers decide whether this
    # launcher should run in the background, which keeps the tracked PID tied to
    # the real worker rather than a short-lived intermediate shell.
    "$SELF" --action-async-refresh "$socket_path" "$output_path" "$token_file" "$token" "$repo_path" \
        >/dev/null 2>&1
}

# Build the expensive "latest activity" list off the critical startup path,
# then ask the running fzf instance to reload from the finished file.
#
# First principles:
# - Startup should not block on hundreds of git log calls.
# - Users still benefit from newest-first ordering once that data exists.
# - The right tradeoff is "show a fast list now, then upgrade it in place."
action_async_refresh() {
    local socket_path="${1:?Missing fzf socket path}"
    local output_path="${2:?Missing activity output path}"
    local token_file="${3:?Missing refresh token file}"
    local expected_token="${4:?Missing refresh token}"
    REPO_PATH="${5:-}"
    local output_q

    require_command git "worktree activity refresh"
    command -v curl >/dev/null 2>&1 || return 0

    wait_for_fzf_socket "$socket_path" || return 0

    [[ -f "$token_file" ]] || return 0
    [[ "$(cat "$token_file" 2>/dev/null)" == "$expected_token" ]] || return 0

    local tmp_output="${output_path}.tmp.$$"
    cmd_list_activity > "$tmp_output" || { rm -f "$tmp_output"; return 0; }

    [[ -f "$token_file" ]] || { rm -f "$tmp_output"; return 0; }
    [[ "$(cat "$token_file" 2>/dev/null)" == "$expected_token" ]] || { rm -f "$tmp_output"; return 0; }

    mv -f "$tmp_output" "$output_path"
    # fzf evaluates reload(...) as a shell command. The temp path comes from
    # mktemp and may live under a TMPDIR with spaces, so quote it before
    # sending it across the socket.
    output_q=$(printf '%q' "$output_path")

    # Ask fzf to keep tracking the current item if possible, then replace the
    # fast list with the enriched activity-sorted list.
    if [[ -n "${WT_CAN_CHANGE_LIST_LABEL:-}" ]]; then
        post_fzf_action "$socket_path" "track-current+reload(cat $output_q)+change-list-label(worktrees · latest activity)" || true
    else
        post_fzf_action "$socket_path" "track-current+reload(cat $output_q)" || true
    fi
}

cmd_preview() {
    local wt_path="$1"

    if [[ ! -d "$wt_path" ]]; then
        echo "${RED}Worktree directory does not exist${NC}"
        echo "${DIM}This worktree may need to be pruned.${NC}"
        return
    fi

    require_command git "preview rendering"

    # ── Worktree ────────────────────────────────────────
    section_header "Worktree"
    printf "  %s%s%s\n" "$BOLD" "$(basename "$wt_path")" "$NC"
    printf "  %s%s%s\n" "$DIM" "$(shorten_path "$wt_path")" "$NC"

    if ! git -C "$wt_path" rev-parse --git-dir >/dev/null 2>&1; then
        section_header "State"
        printf "  %sStale directory%s\n" "$YELLOW" "$NC"
        echo "  ${DIM}This path still exists on disk but is no longer a valid Git worktree.${NC}"
        echo "  ${DIM}Use Ctrl-X to prune the stale worktree entry.${NC}"
        return
    fi

    # ── Branch ──────────────────────────────────────────
    section_header "Branch"
    local branch
    branch=$(git -C "$wt_path" symbolic-ref --short HEAD 2>/dev/null || echo "(detached HEAD)")
    printf "  %s%s%s\n" "$BOLD" "$branch" "$NC"

    # ── Latest Activity ─────────────────────────────────
    # A unified timeline showing the most recent commits from the worktree
    # AND all its submodules, sorted by recency. This gives a complete
    # picture of recent work — in monorepos, most development happens
    # inside submodules, so showing only the worktree's own commits would
    # miss the real activity.
    #
    # Output (top 5 entries):
    #   2h ago     a1b2c3d  fix: auth token refresh               backend
    #   1d ago     e4f5g6h  feat: new dashboard card               frontend
    #   3d ago     i7j8k9l  Bump backend pointer
    #
    # Worktree commits have no label (they're implied).
    # Submodule commits show their source name in dim text.
    #
    # For repos without submodules this just shows the worktree's own
    # recent commits — no label column, nothing different.
    section_header "Latest Activity"
    local now_ts activity_lines=()
    now_ts=$(date +%s)

    # Worktree's own commits (top 3).
    # --format=$'%ct\t%h\t%s' gives us "timestamp<TAB>short_hash<TAB>subject".
    # IFS=$'\t' splits on tabs; the last var (csubj) captures the full
    # subject even if it somehow contains tabs.
    while IFS=$'\t' read -r cts chash csubj; do
        [[ -z "$cts" ]] && continue
        local crel
        crel=$(timestamp_to_relative "$cts" "$now_ts")
        # Store sortable fields first, then format after sorting so preview
        # rendering can adapt to the actual pane width.
        activity_lines+=("${cts}"$'\x1f'"${crel}"$'\x1f'"${chash}"$'\x1f'"${csubj}"$'\x1f')
    done < <(git -C "$wt_path" log -3 --format=$'%ct\t%h\t%s' 2>/dev/null)

    # Submodule commits (top 1 each) — only if submodules exist.
    # We grab 1 commit per submodule to avoid flooding the timeline.
    # Submodule paths are read from .gitmodules config (cheap, no checkout
    # needed), then we git-log only initialized ones.
    if [[ -f "$wt_path/.gitmodules" ]]; then
        local sub_path entry
        while IFS= read -r -d '' entry; do
            [[ -z "$entry" ]] && continue
            sub_path="${entry#*$'\n'}"
            [[ -d "$wt_path/$sub_path" ]] || continue
            while IFS=$'\t' read -r sts shash ssubj; do
                [[ -z "$sts" ]] && continue
                local srel
                srel=$(timestamp_to_relative "$sts" "$now_ts")
                # Submodule entries include the source name so the user can
                # tell which repo the commit came from.
                activity_lines+=("${sts}"$'\x1f'"${srel}"$'\x1f'"${shash}"$'\x1f'"${ssubj}"$'\x1f'"${sub_path}")
            done < <(git -C "$wt_path/$sub_path" log -1 --format=$'%ct\t%h\t%s' HEAD 2>/dev/null)
        done < <(git -C "$wt_path" config --file .gitmodules -z --get-regexp 'submodule\..*\.path' 2>/dev/null)
    fi

    if (( ${#activity_lines[@]} == 0 )); then
        echo "  ${DIM}No commits${NC}"
    else
        # Merge-sort all entries by timestamp (descending), take top 5, then
        # render against the current preview width.
        while IFS=$'\x1f' read -r _ts rel hash subject source; do
            print_activity_line "$rel" "$hash" "$subject" "$source"
        done < <(printf '%s\n' "${activity_lines[@]}" | sort -t$'\x1f' -k1,1 -rn | head -5)
    fi

    # ── Submodules ──────────────────────────────────────
    # Per-submodule detail showing sync state, branch, and latest commit
    # at a glance. Each initialized submodule is a mini git repo, so we
    # query it for the info you'd normally need to cd into it to see.
    #
    # Output:
    #   ✗ *backend            dev            2h ago   fix: auth token refresh
    #   ✓  design-system      v1.90.0        3w ago   chore: bump deps
    #   !  serverless         (not initialized)
    #   ✓  frontend           feat/dash      1d ago   feat: new dashboard card
    #
    # Columns:
    #   Icon    ✓ green = synced, ✗ red = diverged, ! yellow = not initialized
    #           (from `git submodule status` prefix: " "=synced, "+"=diverged, "-"=uninit)
    #   Dirty   * yellow if working tree has staged/unstaged changes, blank if clean
    #           (from `git diff-index --quiet HEAD` — fast, skips untracked files)
    #   Name    submodule path
    #   Branch  current branch via `git symbolic-ref --short HEAD`
    #           falls back to `git describe --all --always` for detached/tagged states
    #   Age     relative time of the latest commit (uses shared now_ts from Latest Activity)
    #   Subject first line of the latest commit message, width-trimmed to fit
    #
    # Not-initialized submodules ("-" prefix from `git submodule status`)
    # have no checkout on disk, so we can only show "(not initialized)".
    if [[ -f "$wt_path/.gitmodules" ]]; then
        section_header "Submodules"

        # `git submodule status` output format (one line per submodule):
        #   <prefix><40-char-sha> <path> (<describe>)
        # where prefix is: " " (synced), "+" (diverged), "-" (not initialized)
        while IFS= read -r line; do
            [[ -z "$line" ]] && continue
            local prefix="${line:0:1}"
            local rest="${line:1}"
            # After stripping the 1-char prefix, format is:
            #   <40-char-sha> <path> (<describe>)
            # Skip the 40-char SHA + space, then strip optional trailing
            # " (describe)" to get the full path (which may contain spaces).
            local name
            name="${rest:41}"
            name="${name% (*}"

            # Not-initialized submodules — no git data available
            if [[ "$prefix" == "-" ]]; then
                printf "  ${YELLOW}!${NC} %-20s ${DIM}(not initialized)${NC}\n" "$name"
                continue
            fi

            # Sync icon — "+" means the checked-out SHA differs from what
            # the superproject recorded (i.e. local submodule changes).
            local sync_icon
            if [[ "$prefix" == "+" ]]; then
                sync_icon="${RED}✗${NC}"
            else
                sync_icon="${GREEN}✓${NC}"
            fi

            local sub_dir="$wt_path/$name"

            # Dirty marker — `git diff-index --quiet HEAD` exits non-zero
            # when there are staged OR unstaged changes (but not untracked
            # files). This is fast because it only stats tracked files.
            local dirty=""
            if [[ -d "$sub_dir" ]]; then
                git -C "$sub_dir" diff-index --quiet HEAD 2>/dev/null || dirty="*"
            fi

            # Branch — try symbolic-ref first (gives "main", "feat/dash"),
            # fall back to describe --all --always for detached/tagged states
            # (gives "v1.90.0", "origin/main", or a short SHA as last resort).
            # We strip verbose prefixes that describe adds (heads/, remotes/, tags/).
            local sub_branch=""
            if [[ -d "$sub_dir" ]]; then
                sub_branch=$(git -C "$sub_dir" symbolic-ref --short HEAD 2>/dev/null) \
                    || sub_branch=$(git -C "$sub_dir" describe --all --always HEAD 2>/dev/null | sed 's|^heads/||;s|^remotes/||;s|^tags/||') \
                    || sub_branch=""
            fi
            sub_branch=$(truncate_str "${sub_branch:-???}" 16)

            # Age + subject from the submodule's latest commit.
            # Same tab-split + parameter expansion pattern used in
            # get_newest_commit(). now_ts comes from the Latest Activity
            # section above so all relative times use a consistent "now".
            local sub_age="—" sub_subject="—"
            if [[ -d "$sub_dir" ]]; then
                local sub_log
                sub_log=$(git -C "$sub_dir" log -1 --format=$'%ct\t%s' HEAD 2>/dev/null) || sub_log=""
                if [[ -n "$sub_log" ]]; then
                    local sub_ts="${sub_log%%	*}"
                    sub_subject="${sub_log#*	}"
                    sub_age=$(timestamp_to_relative "$sub_ts" "$now_ts")
                fi
            fi

            print_submodule_line "$sync_icon" "$dirty" "$name" "$sub_branch" "$sub_age" "$sub_subject"
        done < <(git -C "$wt_path" submodule status 2>/dev/null)
    fi

    # ── Working Tree ────────────────────────────────────
    section_header "Working Tree"
    local modified=0 untracked=0 staged=0
    while IFS= read -r status_line; do
        [[ -z "$status_line" ]] && continue
        local xy="${status_line:0:2}"
        case "$xy" in
            '??') (( untracked++ )) ;;
            *)
                [[ "${xy:0:1}" != " " && "${xy:0:1}" != "?" ]] && (( staged++ )) || true
                [[ "${xy:1:1}" != " " && "${xy:1:1}" != "?" ]] && (( modified++ )) || true
                ;;
        esac
    done < <(git -C "$wt_path" status --porcelain 2>/dev/null)

    if (( modified + untracked + staged == 0 )); then
        printf '  %s\n' "${GREEN}Clean${NC}"
    else
        local summary=""
        (( staged > 0 )) && summary+="${GREEN}$staged staged${NC}"
        if (( modified > 0 )); then
            [[ -n "$summary" ]] && summary+=", "
            summary+="${YELLOW}$modified modified${NC}"
        fi
        if (( untracked > 0 )); then
            [[ -n "$summary" ]] && summary+=", "
            summary+="${DIM}$untracked untracked${NC}"
        fi
        printf "  %s\n" "$summary"
    fi
}

# =============================================================================
# Actions (called from fzf keybindings via self-invocation)
# =============================================================================

action_new() {
    local wt_path="$1"

    require_command git "worktree creation"

    if [[ ! -d "$wt_path" ]]; then
        echo "${RED}Cannot create from a missing worktree. Prune the stale entry first.${NC}"
        return
    fi

    local base
    base=$(dirname "$wt_path")

    printf '%s' "${BOLD}New branch name: ${NC}"
    local branch
    read -r branch

    if [[ -z "$branch" ]]; then
        echo "Cancelled."
        return
    fi

    local new_path="$base/$branch"
    printf "Creating worktree at %s...\n" "$(shorten_path "$new_path")"
    git -C "$wt_path" worktree add "$new_path" -b "$branch" 2>&1
    echo "${GREEN}✓${NC} Created"
}

action_delete() {
    local wt_path
    wt_path=$(canonical_path "$1")

    require_command git "worktree deletion"

    # When invoked from the dashboard, arg 2 is the repo context that launched
    # wt. We use it for stale-entry pruning, because the missing worktree itself
    # may no longer provide a usable Git context.
    local preferred_ctx="${2:-}"
    local short_path
    short_path=$(shorten_path "$wt_path")
    local metadata_state=""
    local state_ctx="${preferred_ctx:-}"

    if [[ -z "$state_ctx" && -d "$wt_path" ]]; then
        state_ctx="$wt_path"
    fi
    if [[ -n "$state_ctx" ]] && ! git -C "$state_ctx" rev-parse --git-dir >/dev/null 2>&1; then
        state_ctx=""
    fi
    if [[ -z "$state_ctx" ]]; then
        state_ctx=$(find_prune_context "$wt_path" "$preferred_ctx" 2>/dev/null || true)
    fi
    if [[ -n "$state_ctx" ]]; then
        IFS=$'\t' read -r metadata_state _metadata_locked <<< "$(worktree_state_from_context "$state_ctx" "$wt_path" 2>/dev/null || true)"
    fi

    # ── Prunable / stale metadata ─────────────────────────────────────
    # Git can mark a worktree "prunable" even when the directory still exists.
    # That usually means the directory is just leftover files and the worktree's
    # gitdir/admin link is broken. Treat Git's stale state as authoritative so
    # Ctrl-X can clean up both the metadata and the leftover directory.
    if [[ "$metadata_state" == "prunable" ]]; then
        echo "${DIM}Git already marks this worktree entry as stale.${NC}"

        if [[ -e "$wt_path" ]]; then
            echo "${DIM}The directory still exists on disk, but it is no longer a valid worktree.${NC}"
            printf '%s%s%s' "${BOLD}Prune metadata and remove leftover directory " "$short_path" "? [y/N] ${NC}"
        else
            printf '%s%s%s' "${BOLD}Prune stale entry " "$short_path" "? [y/N] ${NC}"
        fi

        read -r confirm
        if [[ "$confirm" =~ ^[yY]$ ]]; then
            if prune_worktree_metadata "$wt_path" "$preferred_ctx"; then
                if [[ -e "$wt_path" ]]; then
                    delete_worktree_path "$wt_path" || true
                    if [[ -e "$wt_path" ]]; then
                        echo "${GREEN}✓${NC} Pruned metadata"
                        return 1
                    fi
                    echo "${GREEN}✓${NC} Pruned and removed"
                else
                    echo "${GREEN}✓${NC} Pruned"
                fi
            else
                echo "${RED}Could not find a valid git context to prune from.${NC}"
                echo "${DIM}Try: git worktree prune --expire now (from any checkout of this repo)${NC}"
                return 1
            fi
        else
            echo "Cancelled."
        fi
        return
    fi

    # ── Prunable (directory already gone) ─────────────────────────────
    if [[ ! -e "$wt_path" ]]; then
        echo "${DIM}Directory does not exist — pruning stale entry.${NC}"
        printf '%s%s%s' "${BOLD}Prune " "$short_path" "? [y/N] ${NC}"
        read -r confirm
        if [[ "$confirm" =~ ^[yY]$ ]]; then
            if prune_worktree_metadata "$wt_path" "$preferred_ctx"; then
                echo "${GREEN}✓${NC} Pruned"
            else
                echo "${RED}Could not find a valid git context to prune from.${NC}"
                echo "${DIM}Try: git worktree prune (from any checkout of this repo)${NC}"
            fi
        else
            echo "Cancelled."
        fi
        return
    fi

    if [[ ! -d "$wt_path" ]]; then
        echo "${RED}Path exists but is not a directory:${NC} $short_path"
        return 1
    fi

    # `--action-delete` may be called directly by a user, so validate that the
    # selected path is an actual worktree root before we rely on worktree
    # porcelain output below. Without this guard, a plain directory can trip
    # `set -e` and exit silently.
    if ! worktree_known_to_git_context "$wt_path" "$wt_path"; then
        echo "${RED}Not a git worktree:${NC} $short_path"
        return 1
    fi

    # ── Safety: can't remove the main worktree ────────────────────────
    local main_wt
    main_wt=$(git -C "$wt_path" worktree list --porcelain 2>/dev/null | head -1)
    main_wt=$(canonical_path "${main_wt#worktree }")
    if [[ "$wt_path" == "$main_wt" ]]; then
        echo "${RED}Cannot remove the main worktree.${NC}"
        return
    fi

    # ── Safety: can't remove the worktree you're standing in ──────────
    local current
    current=$(canonical_path "${PWD:-}")
    if [[ "$current" == "$wt_path" || "$current" == "$wt_path/"* ]]; then
        echo "${RED}Cannot remove the current worktree. cd elsewhere first.${NC}"
        return
    fi

    # ── Safety: can't remove a locked worktree ───────────────────────
    # Walk porcelain output to find this worktree's block, then check for
    # a "locked" line before the next "worktree" block begins. Avoids
    # regex (paths may contain special chars) and fixed-window grep.
    local is_locked=false
    local in_block=false
    while IFS= read -r line; do
        if [[ "$line" == "worktree "* ]]; then
            if $in_block; then
                break  # hit next worktree block — done
            fi
            [[ "${line#worktree }" == "$wt_path" ]] && in_block=true
        elif $in_block && [[ "$line" == locked* ]]; then
            is_locked=true
        fi
    done < <(git -C "$wt_path" worktree list --porcelain 2>/dev/null)
    if $is_locked; then
        echo "${RED}Cannot remove a locked worktree.${NC}"
        echo "${DIM}Unlock with: git worktree unlock $(shorten_path "$wt_path")${NC}"
        return
    fi

    # ── Gather state ──────────────────────────────────────────────────
    local branch_name="" is_detached=false
    branch_name=$(git -C "$wt_path" symbolic-ref --short HEAD 2>/dev/null) || is_detached=true

    local status_output="" dirty_count=0
    status_output=$(git -C "$wt_path" status --porcelain 2>/dev/null) || true
    if [[ -n "$status_output" ]]; then
        dirty_count=$(wc -l <<< "$status_output" | tr -d ' ')
    fi

    # ── Display worktree info ─────────────────────────────────────────
    echo ""
    echo "${BOLD}Worktree:${NC} $short_path"
    if $is_detached; then
        local head_sha
        head_sha=$(git -C "$wt_path" rev-parse --short HEAD 2>/dev/null)
        echo "${BOLD}HEAD:${NC}     ${YELLOW}detached at $head_sha${NC}"
    else
        echo "${BOLD}Branch:${NC}  $branch_name ${DIM}(branch will be preserved)${NC}"
    fi

    # ── Dirty working tree → require strong confirmation ──────────────
    if (( dirty_count > 0 )); then
        echo ""
        echo "${YELLOW}⚠ $dirty_count uncommitted change(s) will be lost:${NC}"
        head -10 <<< "$status_output" | while IFS= read -r line; do
            echo "  ${DIM}$line${NC}"
        done
        (( dirty_count > 10 )) && echo "  ${DIM}… and $((dirty_count - 10)) more${NC}"

        if $is_detached; then
            echo ""
            echo "${YELLOW}⚠ Detached HEAD — commits not on any branch may become unreachable.${NC}"
            echo "  ${DIM}Consider: git -C $short_path checkout -b <name>${NC}"
        fi

        echo ""
        echo "${RED}${BOLD}This will permanently delete uncommitted work.${NC}"
        printf '%s' "${BOLD}Type 'delete' to confirm: ${NC}"
        read -r confirm
        if [[ "$confirm" == "delete" ]]; then
            if git -C "$main_wt" worktree remove --force "$wt_path" 2>&1; then
                if [[ -e "$wt_path" ]]; then
                    # Metadata removal succeeded, but the filesystem still has
                    # leftovers. Finish the local cleanup.
                    delete_worktree_path "$wt_path" || true
                fi
            else
                # Force delete was already explicitly confirmed above, so it is
                # safe to fall back to direct filesystem cleanup here.
                warn "git worktree remove --force failed; retrying filesystem cleanup"
                delete_worktree_path "$wt_path" || true
                prune_worktree_metadata "$wt_path" "$main_wt" || true
            fi

            if [[ -e "$wt_path" ]]; then
                return 1
            fi

            prune_worktree_metadata "$wt_path" "$main_wt" || true
            echo "${GREEN}✓${NC} Removed"
        else
            echo "Cancelled."
        fi
        return
    fi

    # ── Clean working tree ────────────────────────────────────────────
    echo ""
    if $is_detached; then
        echo "${DIM}Working tree is clean.${NC}"
        echo "${YELLOW}Note:${NC} Detached HEAD — commits not on any branch may become unreachable."
        echo "  ${DIM}Consider: git -C $short_path checkout -b <name>${NC}"
    else
        echo "${DIM}Working tree is clean. Branch '$branch_name' will be preserved.${NC}"
    fi

    printf '%s' "${BOLD}Remove? [y/N] ${NC}"
    read -r confirm
    if [[ "$confirm" =~ ^[yY]$ ]]; then
        if git -C "$main_wt" worktree remove "$wt_path" 2>&1; then
            if [[ -e "$wt_path" ]]; then
                delete_worktree_path "$wt_path" || true
            fi
        else
            # For a previously clean worktree, do NOT jump straight to rm -rf.
            # Re-check first: new files may have appeared since the first
            # prompt, and those deserve a stronger confirmation.
            if ! confirm_force_delete "$wt_path"; then
                echo "Cancelled."
                return
            fi
            warn "git worktree remove failed; forcing filesystem cleanup"
            delete_worktree_path "$wt_path" || true
            prune_worktree_metadata "$wt_path" "$main_wt" || true
        fi

        if [[ -e "$wt_path" ]]; then
            return 1
        fi

        prune_worktree_metadata "$wt_path" "$main_wt" || true
        echo "${GREEN}✓${NC} Removed"
    else
        echo "Cancelled."
    fi
}

# =============================================================================
# Help & Version
# =============================================================================

show_help() {
    printf '%b' "${BOLD}wt${NC} v${VERSION} — Interactive git worktree dashboard

${BOLD}USAGE${NC}
    wt                  Auto-detect repo from \$PWD
    wt <path>           Use specific repo path

${BOLD}OPTIONS${NC}
    -h, --help          Show this help
    --version           Show version

${BOLD}KEYBINDINGS${NC}
    Enter               cd into selected worktree
    Ctrl-O              Open in \$EDITOR
    Ctrl-P              Pull latest (--ff-only)
    Ctrl-N              Create new worktree
    Ctrl-X              Delete worktree
    Ctrl-R              Refresh list
    Ctrl-/              Toggle preview panel

${BOLD}ICONS${NC}
    ●  Current worktree (\$PWD)
    ○  Has branch
    ◌  Detached HEAD
    ✗  Prunable (stale)
    🔒  Locked

${BOLD}SHELL INTEGRATION${NC}
    Source the wrapper for your shell for cd support:
        source /path/to/share/wt/wt.zsh   # zsh
        source /path/to/share/wt/wt.bash  # bash

${BOLD}REQUIREMENTS${NC}
    git                 Required
    fzf (0.38+)         Required (uses become())
"
}

show_version() {
    echo "wt ${VERSION}"
}

# =============================================================================
# fzf Dashboard
# =============================================================================

launch_fzf() {
    require_command fzf "the interactive dashboard"

    local editor="${EDITOR:-vim}"
    local preview_window
    preview_window=$(choose_preview_window)
    local fzf_help
    local supports_listen=false supports_list_label=false
    local session_dir="" socket_path="" activity_file="" token_file="" pid_file=""
    local async_refresh_cmd="" async_refresh_bind="" async_pid=""
    local -a listen_args=() track_args=() list_label_args=()
    local list_label="worktrees · branch/state"

    # Progressive enhancement:
    # - Older fzf versions still get the fast list and lazy preview.
    # - Newer fzf versions unlock background reloads (--listen) and visible
    #   list-state labels (--list-label).
    #
    # We feature-detect from `fzf --help` instead of assuming the newest flags
    # exist, because wt still aims to run on older machines.
    fzf_help=$(fzf --help 2>/dev/null || true)
    grep -Fq -- "--listen" <<< "$fzf_help" && supports_listen=true
    grep -Fq -- "--list-label" <<< "$fzf_help" && supports_list_label=true

    # Shell-escape script/repo paths for safe embedding in fzf command strings.
    # fzf placeholder fields like {1} are already substituted as shell-quoted
    # strings, so we keep those raw and only quote the static path pieces here.
    local self_q repo_q
    self_q=$(printf '%q' "$SELF")

    local list_cmd="$self_q --list"
    local delete_cmd="$self_q --action-delete {1}"
    if [[ -n "${REPO_PATH:-}" ]]; then
        repo_q=$(printf '%q' "$REPO_PATH")
        list_cmd="$list_cmd $repo_q"
        delete_cmd="$delete_cmd $repo_q"
    fi

    # Async enrichment is optional. If curl is available and fzf supports a
    # local listen socket, we let fzf start with the cheap list immediately,
    # then reload the richer activity-sorted list after a background worker
    # finishes building it.
    if command -v curl >/dev/null 2>&1 && $supports_listen; then
        session_dir=$(mktemp -d "${TMPDIR:-/tmp}/wt.XXXXXXXX") || session_dir=""
        if [[ -n "$session_dir" ]]; then
            socket_path="$session_dir/fzf.sock"
            activity_file="$session_dir/activity.list"
            token_file="$session_dir/refresh.token"
            pid_file="$session_dir/refresh.pid"
            # These values are injected into fzf execute/reload strings, so
            # quote them once up front instead of hoping the temp directory has
            # no spaces or special shell characters.
            local socket_q activity_q token_q pid_q
            socket_q=$(printf '%q' "$socket_path")
            activity_q=$(printf '%q' "$activity_file")
            token_q=$(printf '%q' "$token_file")
            pid_q=$(printf '%q' "$pid_file")
            listen_args+=("--listen=$socket_path")
            track_args+=("--track")
            if $supports_list_label; then
                list_label="worktrees · loading activity..."
                async_refresh_cmd="WT_CAN_CHANGE_LIST_LABEL=1 "
            else
                async_refresh_cmd=""
            fi
            async_refresh_cmd+="$self_q --action-start-async-refresh $socket_q $activity_q $token_q $pid_q"
            if [[ -n "${REPO_PATH:-}" ]]; then
                async_refresh_cmd="$async_refresh_cmd $repo_q"
            fi
            async_refresh_bind="+execute-silent($async_refresh_cmd >/dev/null 2>&1 &)"
        fi
    fi
    if $supports_list_label; then
        list_label_args+=("--list-label=$list_label")
    fi

    # Parse once up front so the header can show the default worktree base path.
    # The list itself will re-parse inside --list, but that extra porcelain
    # parse is cheap. The expensive work now lives in the lazy preview path.
    parse_worktrees
    local base_display=""
    base_display=$(worktree_base_dir)
    if [[ -n "$base_display" ]]; then
        [[ "$base_display" != "/" ]] && base_display="${base_display%/}"
        base_display="$(shorten_path "$base_display")"
    fi

    local list
    list=$(cmd_list)

    if [[ -z "$list" ]]; then
        die "No worktrees found"
    fi

    local header=""
    [[ -n "$base_display" ]] && header="  ${base_display}"$'\n'
    header+="  enter:cd  ^o:editor  ^p:pull  ^n:new  ^x:delete  ^r:refresh  ^/:preview"

    if [[ -n "$async_refresh_cmd" ]]; then
        if $supports_list_label; then
            WT_CAN_CHANGE_LIST_LABEL=1 "$SELF" --action-start-async-refresh "$socket_path" "$activity_file" "$token_file" "$pid_file" "${REPO_PATH:-}" \
                >/dev/null 2>&1 &
        else
            "$SELF" --action-start-async-refresh "$socket_path" "$activity_file" "$token_file" "$pid_file" "${REPO_PATH:-}" \
                >/dev/null 2>&1 &
        fi
        async_pid=$!
    fi

    local result
    # printf is intentional here:
    # - echo has implementation-specific edge cases
    # - the list payload is already complete text
    # - printf keeps the startup path boring and predictable
    result=$(printf '%s\n' "$list" | fzf \
        --ansi \
        --delimiter=$'\x1f' \
        --with-nth=2 \
        "${listen_args[@]}" \
        "${track_args[@]}" \
        --preview="$self_q --preview {1}" \
        --preview-window="$preview_window" \
        --header="$header" \
        --header-first \
        "${list_label_args[@]}" \
        --reverse \
        --no-sort \
        --no-multi \
        --bind="enter:become(echo {1})" \
        --bind="ctrl-o:execute($editor {1})" \
        --bind="ctrl-p:execute(git -C {1} pull --ff-only)+reload($list_cmd)${async_refresh_bind}" \
        --bind="ctrl-r:reload($list_cmd)${async_refresh_bind}" \
        --bind="ctrl-n:execute($self_q --action-new {1} </dev/tty >/dev/tty 2>&1)+reload($list_cmd)${async_refresh_bind}" \
        --bind="ctrl-x:execute($delete_cmd </dev/tty >/dev/tty 2>&1)+reload($list_cmd)${async_refresh_bind}" \
        --bind="ctrl-/:toggle-preview" \
        --pointer="▶" \
        --prompt="worktree▶ " \
    ) || true

    if [[ -n "$async_pid" ]]; then
        kill "$async_pid" >/dev/null 2>&1 || true
    fi
    if [[ -f "$pid_file" ]]; then
        local refresh_pid
        refresh_pid=$(cat "$pid_file" 2>/dev/null || true)
        if [[ "$refresh_pid" =~ ^[0-9]+$ ]] && kill -0 "$refresh_pid" 2>/dev/null; then
            kill "$refresh_pid" >/dev/null 2>&1 || true
        fi
        rm -f "$pid_file"
    fi
    if [[ -n "$session_dir" ]]; then
        rm -rf "$session_dir"
    fi

    # Output result (path for cd wrapper, or empty on escape)
    if [[ -n "$result" ]]; then
        printf '%s\n' "$result"
    fi
}

# =============================================================================
# Main
# =============================================================================

main() {
    REPO_PATH=""

    case "${1:-}" in
        -h|--help)
            show_help
            return 0
            ;;
        --version)
            show_version
            return 0
            ;;
        --preview)
            cmd_preview "${2:?Missing worktree path for --preview}"
            return 0
            ;;
        --list)
            REPO_PATH="${2:-}"
            cmd_list
            return 0
            ;;
        --list-activity)
            REPO_PATH="${2:-}"
            cmd_list_activity
            return 0
            ;;
        --action-new)
            action_new "${2:?Missing worktree path for --action-new}"
            return 0
            ;;
        --action-delete)
            action_delete "${2:?Missing worktree path for --action-delete}" "${3:-}"
            return 0
            ;;
        --action-start-async-refresh)
            start_async_refresh "${2:?Missing fzf socket path}" "${3:?Missing activity output path}" "${4:?Missing refresh token file}" "${5:?Missing refresh pid file}" "${6:-}"
            return 0
            ;;
        --action-async-refresh)
            action_async_refresh "${2:?Missing fzf socket path}" "${3:?Missing activity output path}" "${4:?Missing refresh token file}" "${5:?Missing refresh token}" "${6:-}"
            return 0
            ;;
        -*)
            die "Unknown option: $1. See 'wt --help'."
            ;;
        *)
            REPO_PATH="${1:-}"
            ;;
    esac

    # Help and version are intentionally handled above without requiring Git.
    # Everything below this point either inspects a repository or launches the
    # dashboard, so Git is a real hard dependency from here on.
    require_command git "repository inspection"

    # Verify we're in a git repository
    if [[ -n "$REPO_PATH" ]]; then
        git -C "$REPO_PATH" rev-parse --git-dir >/dev/null 2>&1 \
            || die "Not a git repository: $REPO_PATH"
    else
        git rev-parse --git-dir >/dev/null 2>&1 \
            || die "Not inside a git repository. Usage: wt [path]"
    fi

    launch_fzf
}

main "$@"
